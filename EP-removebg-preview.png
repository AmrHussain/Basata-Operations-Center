/* ............................................................................global rules .....................................................................................*/

*{
    box-sizing: border-box;
    padding: 0;
    margin: 0;
}



/* ......................................................................... Media Querry Codes ...............................................................................*/


.container{
    margin: 0 auto;
}

/* small mobile screen */
@media (max-width:490px){

    .container{
        margin: 0 10px;
        width: auto;
    }
}

/* large mobile screen */
@media (min-width:490px) and (max-width:768px){

    .container{
        margin: 0 50px;
        max-width: 600px;
    }
}
/* <!-- small --> */

@media (min-width:768px) and (max-width:992px){

.container{
    max-width: 800px;
}

}
/* <!-- medium --> */
@media (min-width:992px) and  (max-width:1200px){

.container{
    width: 970px;
}

}
/* <!-- larg --> */
@media (min-width:1200px){

.container{
    width: 1170px;
}

}


/* ...............................................................................colors panel......................................................................................... */


/*................................................................................. body............................................................................................. */

body{
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: 15% 75% 10%;
    grid-template-areas: 
    " nav nav nav nav nav"
    "header header header header header"
    "footer footer footer footer footer";
    justify-content: center;
    align-items: center;
    font-family: 'Open Sans', sans-serif;
    background-size: contain;
    background-attachment: fixed;
    background-repeat: no-repeat;
    background-color: var(--backgound-color);
    height: 100vh;
    color: #ffffff;
    background-color: #28282B;
}


a{
    color: #ffffff;
    text-decoration: none;
}

/* .................................................................................navbar............................................................................................ */
nav{
    display: block;
    width: 100vw ;
}

nav .container{
    margin-top: 100px;
    display: flex;
    justify-content: center;
    justify-items: center;

}
    





/* ......................................................................................header........................................................................................ */

header{
    grid-area: header;
    text-align: left;
}

header div h3 {
    margin-top: 60px;
    color: #e01a29;

}

header div ul{
    margin-left: 40px;
    margin-top: 10px;
    white-space: normal;
}
header div ul li a:hover{
    color: #e01a29;
    font-weight: bold;
    transition:.3s;
    
}
i:hover{
    color: #e01a29;
    transition: .3s;
}

header .container .box{
    display: flex;
    flex-flow: row wrap;
    justify-content: space-between;
    align-items: top; 
    font-size: 26px;
}




@media (min-width:768px) and (max-width:992px){
    header .container .box{
        flex-flow: column wrap;
        justify-content: space-between;
        
    }

    header .container .box  div:first-child,
    header .container .box  div:last-child{
        width: 100%;
    }

    header .container .box  div h1{
        margin-top: 50px;
        text-align: center;
        font-size: 35px;
    
    }
    header .container .box  div p{
        text-align: center;
        font-size: 15px;
    
    }

    header .container .box  div:first-child img{
        width: 80%;
    }

    header .container .box  div button{
        align-self: center;
        padding: 18px 100px;
    }
}

@media (max-width:768px){

    header .container .box{
        flex-flow: column wrap;
        justify-content: space-between;
        
    }

    header .container .box  div:first-child,
    header .container .box  div:last-child{
        width: 100%;
    }

    header .container .box  div h1{
        margin-top: 50px;
        text-align: center;
        font-size: 25px;
    
    }
    header .container .box  div p{
        text-align: center;
        font-size: 15px;
    
    }

    header .container .box  div:first-child img{
        width: 100%;
    }

    header .container .box  div button{
        align-self: center;
        padding: 18px 50px;
    }
}

/* ..................................................................................footer......................................................................................... */

footer{
    grid-area: footer;
}

.icons-box{
    display: flex;
    justify-content: flex-end;
}

footer .container .icons-box div {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 0 10px;
    width: 40px;
    height: 40px;
    border: .5px solid var(--background-color);
    border-radius: 50%;
}

footer div i{
    font-size: 20px;
    color: var(--background-color);
}

@media (max-width:992px){
    .icons-box{
        display: flex;
        justify-content: center;
    }

}

